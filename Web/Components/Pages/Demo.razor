@page "/Demo"
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Demo</PageTitle>

<canvas @ref="_canvasRef"
        id="arcanoid-canvas"
        tabindex="0"
        style="width:100%;max-width:800px;aspect-ratio:4/3;background:#000;display:block;"></canvas>

@code {
    private ElementReference _canvasRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _handle;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "/game/main.js");
        _handle = await _module.InvokeAsync<IJSObjectReference>("start", _canvasRef);
    }

    public async ValueTask DisposeAsync()
    {
        if (_handle is not null)
        {
            try { await _handle.InvokeVoidAsync("stop"); } catch { }
            try { await _handle.DisposeAsync(); } catch { }
        }
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
        }
    }
}
